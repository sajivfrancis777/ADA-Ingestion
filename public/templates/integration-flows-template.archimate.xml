<?xml version="1.0" encoding="UTF-8"?>
<!--
  ADA Integration Flows Template — ArchiMate Open Exchange Format
  
  Compatible with: BiZZdesign Enterprise Studio, Archi, Sparx EA (ArchiMate import)
  
  USAGE:
    1. Import this file into your ArchiMate tool
    2. Add your elements (ApplicationComponent, Node, etc.) to the appropriate views
    3. Create Flow/Serving/Access relationships between source and target systems
    4. Export as ArchiMate Open Exchange (.xml) and upload via ADA Editor
  
  VIEW NAMING CONVENTION (parser detects these automatically):
    - "Current State"         → release=All,  state=Current
    - "R1 - Future State"     → release=R1,   state=Future
    - "R2 - Future State"     → release=R2,   state=Future
    - "R3 - Future State"     → release=R3,   state=Future
    - "R4 - Future State"     → release=R4,   state=Future
  
  The parser extracts:
    - Source System = source element name
    - Target System = target element name  
    - Interface/Technology = relationship name (label your relationships!)
    
  TIPS:
    - Use ApplicationComponent for software systems (SAP S/4HANA, MuleSoft, etc.)
    - Use Node for infrastructure/hardware if needed
    - Use FlowRelationship for data flows, ServingRelationship for service calls
    - ALWAYS label relationships with the interface technology
    - You can add/rename views — parser detects R1-R9, Wave, Phase, etc.
    - Delete unused release views if not needed
-->
<model xmlns="http://www.opengroup.org/xsd/archimate/3.0/"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.opengroup.org/xsd/archimate/3.0/ http://www.opengroup.org/xsd/archimate/3.1/archimate3_Diagram.xsd"
       identifier="id-ada-template-001"
       version="1.0">
  
  <name xml:lang="en">ADA Integration Flows Template</name>
  
  <!-- ═══════════════════════════════════════════════════════════════
       ELEMENTS — Add your systems here as ApplicationComponent elements.
       Example elements shown below; replace with your actual systems.
       ═══════════════════════════════════════════════════════════════ -->
  <elements>
    <!-- Example: Source system -->
    <element identifier="id-elem-source-example" xsi:type="ApplicationComponent">
      <name xml:lang="en">Source System (replace me)</name>
      <documentation xml:lang="en">Replace with your source application name, e.g. SAP S/4HANA</documentation>
    </element>
    
    <!-- Example: Target system -->
    <element identifier="id-elem-target-example" xsi:type="ApplicationComponent">
      <name xml:lang="en">Target System (replace me)</name>
      <documentation xml:lang="en">Replace with your target application name, e.g. Snowflake PDH</documentation>
    </element>
    
    <!-- Example: Middleware -->
    <element identifier="id-elem-middleware-example" xsi:type="ApplicationComponent">
      <name xml:lang="en">Middleware (replace me)</name>
      <documentation xml:lang="en">Replace with middleware name, e.g. MuleSoft Anypoint</documentation>
    </element>
  </elements>
  
  <!-- ═══════════════════════════════════════════════════════════════
       RELATIONSHIPS — Connect your systems here.
       The relationship NAME becomes "Interface / Technology" in the grid.
       ═══════════════════════════════════════════════════════════════ -->
  <relationships>
    <!-- Example: Source → Middleware via IDoc -->
    <relationship identifier="id-rel-001" xsi:type="FlowRelationship"
                  source="id-elem-source-example" target="id-elem-middleware-example">
      <name xml:lang="en">IDoc (replace with actual interface technology)</name>
    </relationship>
    
    <!-- Example: Middleware → Target via REST API -->
    <relationship identifier="id-rel-002" xsi:type="FlowRelationship"
                  source="id-elem-middleware-example" target="id-elem-target-example">
      <name xml:lang="en">REST API (replace with actual interface technology)</name>
    </relationship>
  </relationships>
  
  <!-- ═══════════════════════════════════════════════════════════════
       VIEWS — Each view = one tab in the parser output.
       Name your views using the convention below.
       Parser detects release + state from view names automatically.
       ═══════════════════════════════════════════════════════════════ -->
  <views>
    <diagrams>
      <!-- Current State view -->
      <view identifier="id-view-current" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">Current State</name>
        <documentation xml:lang="en">As-is integration landscape before any releases</documentation>
        <!-- Add your element nodes and relationship connections here -->
        <node identifier="id-vn-01" elementRef="id-elem-source-example" x="100" y="200" w="160" h="80"/>
        <node identifier="id-vn-02" elementRef="id-elem-target-example" x="500" y="200" w="160" h="80"/>
        <connection identifier="id-vc-01" relationshipRef="id-rel-001" source="id-vn-01" target="id-vn-02"/>
      </view>
      
      <!-- R1 - Future State view -->
      <view identifier="id-view-r1" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R1 - Future State</name>
        <documentation xml:lang="en">Release 1 target integration architecture</documentation>
        <!-- Add R1 elements and connections here -->
        <node identifier="id-vn-r1-01" elementRef="id-elem-source-example" x="100" y="200" w="160" h="80"/>
        <node identifier="id-vn-r1-02" elementRef="id-elem-middleware-example" x="300" y="200" w="160" h="80"/>
        <node identifier="id-vn-r1-03" elementRef="id-elem-target-example" x="500" y="200" w="160" h="80"/>
        <connection identifier="id-vc-r1-01" relationshipRef="id-rel-001" source="id-vn-r1-01" target="id-vn-r1-02"/>
        <connection identifier="id-vc-r1-02" relationshipRef="id-rel-002" source="id-vn-r1-02" target="id-vn-r1-03"/>
      </view>
      
      <!-- R2 - Future State view -->
      <view identifier="id-view-r2" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R2 - Future State</name>
        <documentation xml:lang="en">Release 2 target integration architecture</documentation>
      </view>
      
      <!-- R3 - Future State view -->
      <view identifier="id-view-r3" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R3 - Future State</name>
        <documentation xml:lang="en">Release 3 target integration architecture</documentation>
      </view>
      
      <!-- R4 - Future State view -->
      <view identifier="id-view-r4" xsi:type="Diagram" viewpoint="Application Cooperation">
        <name xml:lang="en">R4 - Future State</name>
        <documentation xml:lang="en">Release 4 target integration architecture</documentation>
      </view>
    </diagrams>
  </views>
</model>
